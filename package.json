{
  "name": "obsidian-chats2md",
  "version": "1.0.0",
  "description": "Obsidian plugin for importing full ChatGPT conversation logs into markdown notes.",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production && node scripts/build-plugin-zip.mjs",
    "build:zip": "node scripts/build-plugin-zip.mjs",
    "version": "node scripts/version-bump.mjs && git add manifest.json versions.json",
    "setup:sample-vault": "node scripts/setup-sample-vault.mjs",
    "e2e:setup": "node scripts/setup-e2e.mjs",
    "e2e:bootstrap": "npm run e2e:setup && node scripts/bootstrap-e2e.mjs",
    "e2e": "npm run build && npm run e2e:setup && playwright test",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,js,mjs}\" \"test/**/*.{ts,js,mjs,json}\" \"scripts/**/*.{ts,js,mjs}\" \"esbuild.config.mjs\" \"eslint.config.mjs\" \"README.md\" \"styles.css\" \"manifest.json\" \"package.json\" \"tsconfig.json\" \"versions.json\"",
    "format:check": "prettier --check \"src/**/*.{ts,js,mjs}\" \"test/**/*.{ts,js,mjs,json}\" \"scripts/**/*.{ts,js,mjs}\" \"esbuild.config.mjs\" \"eslint.config.mjs\" \"README.md\" \"styles.css\" \"manifest.json\" \"package.json\" \"tsconfig.json\" \"versions.json\"",
    "test": "tsx --test test/*.test.mjs test/*.test.ts",
    "test:coverage": "c8 --check-coverage --lines 50 --functions 50 --branches 50 --statements 50 tsx --test test/*.test.mjs test/*.test.ts"
  },
  "keywords": [
    "obsidian",
    "chatgpt",
    "markdown"
  ],
  "license": "MIT",
  "devDependencies": {
    "@electron/asar": "^4.2.0",
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^1.2.0",
    "@playwright/test": "^1.59.1",
    "@types/node": "^24.5.2",
    "c8": "^10.1.3",
    "electron": "^39.8.7",
    "esbuild": "^0.25.10",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-obsidianmd": "^0.1.9",
    "globals": "^17.4.0",
    "jszip": "^3.10.1",
    "prettier": "^3.8.1",
    "tslib": "^2.8.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.58.0"
  },
  "dependencies": {
    "obsidian": "latest"
  }
}
